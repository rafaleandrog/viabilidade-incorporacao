# ============================================================
# Helpers de formatação
# ============================================================

def _safe_float(x: Any) -> float:
    try:
        if x is None:
            return 0.0
        return float(x)
    except Exception:
        return 0.0


def _clamp_pct(x: Any) -> float:
    v = _safe_float(x)
    return max(0.0, min(100.0, v))


def fmt_num_ptbr(n: float, decimals: int = 0) -> str:
    """Formata número com milhares '.' e decimal ',' (estilo PT/BR)."""
    if n is None or (isinstance(n, float) and math.isnan(n)):
        return "-"
    s = f"{abs(n):,.{decimals}f}"  # 1,234,567.89
    s = s.replace(",", "X").replace(".", ",").replace("X", ".")  # 1.234.567,89
    if decimals == 0:
        s = s.split(",")[0]
    if n < 0:
        return f"({s})"
    return s


def fmt_money_plain(n: float) -> str:
    return fmt_num_ptbr(n, decimals=0)


def fmt_currency(n: float) -> str:
    return f"R$ {fmt_money_plain(n)}"


def fmt_pct(p: float, decimals: int = 2) -> str:
    if p is None or (isinstance(p, float) and math.isnan(p)):
        return "-"
    s = f"{p:.{decimals}f}".replace(".", ",")
    return f"{s}%"


def pct_of_vgv(value: float, vgv: float, signed: bool = False) -> float:
    if vgv <= 0:
        return 0.0
    return (value / vgv * 100.0) if signed else (abs(value) / vgv * 100.0)


