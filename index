def build_proforma_lines(res: Dict[str, float]) -> List[Dict[str, Any]]:
    vgv = res["vgv_r"]

    # valores (custos positivos “em módulo”, mas vamos exibir como negativos na coluna R$)
    corret = res["corretagem_r"]
    mkt = res["marketing_vendas_r"]
    house = res["house_total_r"]
    perm_fin = res["permuta_financeira_r"]

    terreno = res["terreno_total_r"]
    obras = res["custo_obras_total_r"]
    infra = res["custo_infra_total_r"]
    proj = res["custo_projeto_lic_r"]
    reg = res["custo_registro_r"]
    manut = res["manut_pos_obra_r"]

    rec_liq = res["receita_liquida_r"]
    res_op = res["resultado_operacional_r"]
    impostos = res["impostos_r"]
    adm = res["adm_gestao_r"]
    res_final = res["resultado_final_r"]

    def line(label: str, value: float, pct: float, kind: str = "normal", show_pct: bool = True):
        return {
            "label": label,
            "value": value,
            "pct": pct,
            "kind": kind,
            "show_pct": show_pct,
        }

    lines: List[Dict[str, Any]] = []
    lines.append(line("Receita bruta (VGV)", vgv, 100.0, kind="section"))

    lines.append(line("Corretagem", -corret, pct_of_vgv(corret, vgv, signed=False)))
    lines.append(line("Marketing e vendas", -mkt, pct_of_vgv(mkt, vgv, signed=False)))
    lines.append(line("Pagamento fixo - house", -house, pct_of_vgv(house, vgv, signed=False)))
    lines.append(line("Permuta financeira", -perm_fin, pct_of_vgv(perm_fin, vgv, signed=False)))

    lines.append(line("Receita líquida", rec_liq, pct_of_vgv(rec_liq, vgv, signed=True), kind="subtotal"))

    lines.append(line("Pagamento do terreno", -terreno, pct_of_vgv(terreno, vgv, signed=False), kind="costblock"))

    lines.append(line("Custo Obras Total", -obras, pct_of_vgv(obras, vgv, signed=False), kind="costblock-strong"))
    lines.append(line("  Infraestrutura", -infra, pct_of_vgv(infra, vgv, signed=False)))
    lines.append(line("  Projecto e licenciamento", -proj, pct_of_vgv(proj, vgv, signed=False)))
    lines.append(line("  Registo", -reg, pct_of_vgv(reg, vgv, signed=False)))
    lines.append(line("  Manutenção pós-obra", -manut, pct_of_vgv(manut, vgv, signed=False)))

    lines.append(line("Resultado operacional", res_op, pct_of_vgv(res_op, vgv, signed=True), kind="subtotal"))

    lines.append(line("Impostos sobre vendas", -impostos, pct_of_vgv(impostos, vgv, signed=False)))
    lines.append(line("Administração e gestão", -adm, pct_of_vgv(adm, vgv, signed=False)))

    lines.append(line("Resultado final", res_final, pct_of_vgv(res_final, vgv, signed=True), kind="result"))
    return lines


def render_proforma_html(nome_projeto: str, lines: List[Dict[str, Any]]) -> str:
    css = """
    <style>
      .pf-wrap{font-family: ui-sans-serif,system-ui,-apple-system,Segoe UI,Roboto,Arial;
               border-radius:12px; overflow:hidden; border:1px solid rgba(0,0,0,0.08)}
      .pf-title{background:#0b4f55; color:white; padding:10px 14px; font-weight:800; letter-spacing:.5px; text-align:center}
      .pf-name{background:#106a72; color:white; padding:8px 14px; font-weight:700}
      table.pf{width:100%; border-collapse:collapse}
      table.pf td{padding:6px 10px; font-size:14px}
      td.lbl{color:white; font-weight:600}
      td.val, td.pct{background:rgba(255,255,255,0.92); text-align:right; font-variant-numeric: tabular-nums}
      tr.section td{background:#0b4f55}
      tr.subtotal td{background:#0b4f55}
      tr.coststrong td{background:#a85a00}
      tr.costblock td{background:#137b84}
      tr.normal td{background:#18a2ad}
      tr.result td{background:#2f6f2f}
      .hdr{background:#0b4f55; color:white; font-weight:800}
      .hdr td{font-size:13px}
      .muted{opacity:0.9; font-weight:500}
    </style>
    """

    header = """
    <div class="pf-wrap">
      <div class="pf-title">PROFORMA LOTEAMENTO</div>
      <div class="pf-name">%s</div>
      <table class="pf">
        <tr class="hdr">
          <td class="lbl"></td>
          <td class="val">R$</td>
          <td class="pct">%% VGV</td>
        </tr>
    """ % (nome_projeto.replace("<", "&lt;").replace(">", "&gt;"))

    rows = []
    for r in lines:
        kind = r["kind"]
        tr_class = "normal"
        if kind == "section":
            tr_class = "section"
        elif kind == "subtotal":
            tr_class = "subtotal"
        elif kind == "result":
            tr_class = "result"
        elif kind == "costblock-strong":
            tr_class = "coststrong"
        elif kind == "costblock":
            tr_class = "costblock"

        label = r["label"]
        value = float(r["value"])
        pct = float(r["pct"])
        rows.append(
            f"""
            <tr class="{tr_class}">
              <td class="lbl">{label}</td>
              <td class="val">{fmt_money_plain(value)}</td>
              <td class="pct">{fmt_pct(pct,2)}</td>
            </tr>
            """
        )

    footer = """
      </table>
    </div>
    """
    return css + header + "\n".join(rows) + footer


