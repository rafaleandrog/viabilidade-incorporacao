@dataclass
class LoteamentoInputs:
    nome_projeto: str = "Calliandra"

    # Área (m²)
    area_total_ofertada_m2: float = 426_029.97
    area_app_m2: float = 0.0
    area_remanescente_m2: float = 48_013.58
    area_nao_edificante_m2: float = 0.0

    # Distribuição da área loteável (%)
    pct_institucional: float = 5.0
    pct_publica: float = 15.0
    pct_viario: float = 30.0

    # Produto
    n_lotes: int = 500
    area_lote_medio_m2: float = 378.0

    # Preço
    preco_venda_r_m2: float = 750.0

    # Permutas
    permuta_fisica_pct_area: float = 0.0        # % sobre área líquida de vendas (área em lotes)
    permuta_financeira_pct_vgv: float = 0.0     # % sobre VGV

    # Custos por VGV
    corretagem_pct_vgv: float = 5.50
    marketing_vendas_pct_vgv: float = 2.11
    impostos_pct_vgv: float = 4.00
    adm_gestao_pct_vgv: float = 1.00

    # Opcional: “pagamento fixo – house”
    house_r_mes: float = 0.0
    house_n_corretores: int = 6
    house_meses: int = 6

    # Terreno
    terreno_r_m2: float = 0.0  # aplicado sobre área total ofertada

    # Custos de obra
    custo_infra_r_m2_area_loteavel: float = 0.0   # R$/m² por área loteável
    custo_projeto_lic_r: float = 0.0              # R$
    custo_registro_r: float = 0.0                 # R$
    manut_pos_obra_pct_sobre_obra: float = 0.0    # % sobre custo de infra (por simplicidade)


def compute_loteamento(ins: LoteamentoInputs) -> Dict[str, float]:
    # --- Área base
    area_total = max(0.0, ins.area_total_ofertada_m2)
    area_loteavel = max(0.0, area_total - ins.area_app_m2 - ins.area_remanescente_m2 - ins.area_nao_edificante_m2)

    # --- Distribuição
    pct_inst = _clamp_pct(ins.pct_institucional)
    pct_pub = _clamp_pct(ins.pct_publica)
    pct_viario = _clamp_pct(ins.pct_viario)
    soma_pct = pct_inst + pct_pub + pct_viario
    pct_vendavel = max(0.0, 100.0 - soma_pct)  # residual

    area_inst = area_loteavel * pct_inst / 100.0
    area_pub = area_loteavel * pct_pub / 100.0
    area_viario = area_loteavel * pct_viario / 100.0
    area_lotes_vendavel = max(0.0, area_loteavel - area_inst - area_pub - area_viario)

    # --- Produto (área em lotes)
    n_lotes = max(0, int(ins.n_lotes))
    area_lote_medio = max(0.0, ins.area_lote_medio_m2)
    area_total_lotes = n_lotes * area_lote_medio

    # --- Permuta física (% sobre área em lotes)
    permuta_fis_pct = _clamp_pct(ins.permuta_fisica_pct_area)
    area_permuta_fis = area_total_lotes * permuta_fis_pct / 100.0
    area_liquida_venda = max(0.0, area_total_lotes - area_permuta_fis)

    # --- Preço e receitas
    preco_m2 = max(0.0, ins.preco_venda_r_m2)
    ticket_medio = area_lote_medio * preco_m2

    vgv_potencial = area_total_lotes * preco_m2
    vgv = area_liquida_venda * preco_m2
    perda_permuta_fis = max(0.0, vgv_potencial - vgv)

    # --- Deduções comerciais e permuta financeira
    permuta_fin_pct = _clamp_pct(ins.permuta_financeira_pct_vgv)
    permuta_fin = vgv * permuta_fin_pct / 100.0

    corretagem = vgv * _clamp_pct(ins.corretagem_pct_vgv) / 100.0
    marketing = vgv * _clamp_pct(ins.marketing_vendas_pct_vgv) / 100.0

    house_total = max(0.0, ins.house_r_mes) * max(0, int(ins.house_n_corretores)) * max(0, int(ins.house_meses))

    receita_liquida = vgv - corretagem - marketing - house_total - permuta_fin

    # --- Terreno
    terreno_total = max(0.0, ins.terreno_r_m2) * area_total

    # --- Obras
    infra_total = max(0.0, ins.custo_infra_r_m2_area_loteavel) * area_loteavel
    manut_pos = infra_total * _clamp_pct(ins.manut_pos_obra_pct_sobre_obra) / 100.0
    custo_obras_total = infra_total + max(0.0, ins.custo_projeto_lic_r) + max(0.0, ins.custo_registro_r) + manut_pos

    resultado_operacional = receita_liquida - terreno_total - custo_obras_total

    # --- Indirectos (por VGV)
    impostos = vgv * _clamp_pct(ins.impostos_pct_vgv) / 100.0
    adm_gestao = vgv * _clamp_pct(ins.adm_gestao_pct_vgv) / 100.0

    resultado_final = resultado_operacional - impostos - adm_gestao

    return {
        # áreas
        "area_total_ofertada_m2": area_total,
        "area_loteavel_m2": area_loteavel,
        "pct_institucional": pct_inst,
        "pct_publica": pct_pub,
        "pct_viario": pct_viario,
        "pct_lotes_vendavel": pct_vendavel,
        "area_institucional_m2": area_inst,
        "area_publica_m2": area_pub,
        "area_viario_m2": area_viario,
        "area_lotes_vendavel_m2": area_lotes_vendavel,
        # produto
        "n_lotes": float(n_lotes),
        "area_lote_medio_m2": area_lote_medio,
        "area_total_lotes_m2": area_total_lotes,
        # permutas
        "permuta_fisica_pct_area": permuta_fis_pct,
        "area_liquida_venda_m2": area_liquida_venda,
        # preço/receitas
        "preco_venda_r_m2": preco_m2,
        "ticket_medio_r": ticket_medio,
        "vgv_potencial_r": vgv_potencial,
        "vgv_r": vgv,
        "perda_permuta_fisica_r": perda_permuta_fis,
        # deduções
        "permuta_financeira_pct_vgv": permuta_fin_pct,
        "permuta_financeira_r": permuta_fin,
        "corretagem_pct_vgv": _clamp_pct(ins.corretagem_pct_vgv),
        "corretagem_r": corretagem,
        "marketing_vendas_pct_vgv": _clamp_pct(ins.marketing_vendas_pct_vgv),
        "marketing_vendas_r": marketing,
        "house_r_mes": max(0.0, ins.house_r_mes),
        "house_n_corretores": float(max(0, int(ins.house_n_corretores))),
        "house_meses": float(max(0, int(ins.house_meses))),
        "house_total_r": house_total,
        # custos
        "terreno_r_m2": max(0.0, ins.terreno_r_m2),
        "terreno_total_r": terreno_total,
        "custo_infra_r_m2_area_loteavel": max(0.0, ins.custo_infra_r_m2_area_loteavel),
        "custo_infra_total_r": infra_total,
        "custo_projeto_lic_r": max(0.0, ins.custo_projeto_lic_r),
        "custo_registro_r": max(0.0, ins.custo_registro_r),
        "manut_pos_obra_pct_sobre_obra": _clamp_pct(ins.manut_pos_obra_pct_sobre_obra),
        "manut_pos_obra_r": manut_pos,
        "custo_obras_total_r": custo_obras_total,
        # resultados
        "receita_liquida_r": receita_liquida,
        "resultado_operacional_r": resultado_operacional,
        "impostos_pct_vgv": _clamp_pct(ins.impostos_pct_vgv),
        "impostos_r": impostos,
        "adm_gestao_pct_vgv": _clamp_pct(ins.adm_gestao_pct_vgv),
        "adm_gestao_r": adm_gestao,
        "resultado_final_r": resultado_final,
        # margens
        "margem_operacional_pct_vgv": pct_of_vgv(resultado_operacional, vgv, signed=True),
        "margem_final_pct_vgv": pct_of_vgv(resultado_final, vgv, signed=True),
        # validação útil
        "soma_pct_distribuicao": soma_pct,
    }


