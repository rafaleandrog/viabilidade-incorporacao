def _load_service_account_info() -> Dict[str, Any]:
    """
    Carrega credenciais a partir de:
    - env var GOOGLE_SERVICE_ACCOUNT_JSON (string JSON)
    - ou env var GOOGLE_SERVICE_ACCOUNT_FILE (path para json)
    """
    json_str = os.getenv("GOOGLE_SERVICE_ACCOUNT_JSON", "").strip()
    if json_str:
        return json.loads(json_str)

    json_file = os.getenv("GOOGLE_SERVICE_ACCOUNT_FILE", "").strip()
    if json_file:
        with open(json_file, "r", encoding="utf-8") as f:
            return json.load(f)

    raise RuntimeError(
        "Credenciais não encontradas. Defina GOOGLE_SERVICE_ACCOUNT_JSON (conteúdo) "
        "ou GOOGLE_SERVICE_ACCOUNT_FILE (caminho)."
    )


@st.cache_resource
def _get_gspread_client():
    import gspread
    from google.oauth2.service_account import Credentials

    info = _load_service_account_info()
    scopes = [
        "https://www.googleapis.com/auth/spreadsheets",
        "https://www.googleapis.com/auth/drive",
    ]
    creds = Credentials.from_service_account_info(info, scopes=scopes)
    return gspread.authorize(creds)


def ensure_sheet_template(ws) -> None:
    """
    Garante que a worksheet tem:
    - header row compatível com SHEET_HEADERS
    - congelamento da primeira linha
    - formatação básica do header
    """
    from gspread_formatting import (
        CellFormat,
        Color,
        TextFormat,
        format_cell_range,
        set_frozen,
    )
    from gspread.utils import rowcol_to_a1

    # Header
    existing = ws.row_values(1)
    if existing[: len(SHEET_HEADERS)] != SHEET_HEADERS:
        ws.update("A1", [SHEET_HEADERS])

    # Freeze primeira linha
    set_frozen(ws, rows=1)

    # Formatar header (A1:...1)
    last = rowcol_to_a1(1, len(SHEET_HEADERS))
    header_range = f"A1:{last}"
    header_fmt = CellFormat(
        backgroundColor=Color(0.043, 0.31, 0.333),  # aproximado #0b4f55
        textFormat=TextFormat(bold=True, foregroundColor=Color(1, 1, 1)),
    )
    format_cell_range(ws, header_range, header_fmt)


def append_study_to_google_sheet(row: Dict[str, Any]) -> None:
    gc = _get_gspread_client()
    sh = gc.open_by_key(SPREADSHEET_ID)
    ws = sh.worksheet(WORKSHEET_NAME)

    ensure_sheet_template(ws)

    ordered = [row.get(h, "") for h in SHEET_HEADERS]
    ws.append_row(ordered, value_input_option="USER_ENTERED")


