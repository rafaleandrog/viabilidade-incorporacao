    for r in proforma:
        pf_rows.append([r["label"], fmt_money_plain(r["value"]), fmt_pct(r["pct"], 2)])
    t3 = Table(pf_rows, colWidths=[260, 80, 80])
    t3.setStyle(TableStyle([
        ("BACKGROUND", (0, 0), (-1, 0), colors.HexColor("#0b4f55")),
        ("TEXTCOLOR", (0, 0), (-1, 0), colors.white),
        ("FONTNAME", (0, 0), (-1, 0), "Helvetica-Bold"),
        ("GRID", (0, 0), (-1, -1), 0.3, colors.grey),
        ("ALIGN", (1, 1), (-1, -1), "RIGHT"),
    ]))
    story.append(t3)

    doc.build(story)
    return buf.getvalue()


def generate_excel_bytes(fase: str, tipo: str, ins: LoteamentoInputs, res: Dict[str, float]) -> bytes:
    from openpyxl import Workbook
    from openpyxl.styles import Alignment, Font, PatternFill
    from openpyxl.worksheet.table import Table, TableStyleInfo

    wb = Workbook()
    ws = wb.active
    ws.title = "Resumo"

    header_fill = PatternFill("solid", fgColor="0B4F55")
    header_font = Font(color="FFFFFF", bold=True)

    ws["A1"] = APP_TITLE
    ws["A1"].font = Font(bold=True, size=14)
    ws["A2"] = "Fase"
    ws["B2"] = fase
    ws["A3"] = "Tipo"
    ws["B3"] = tipo
    ws["A4"] = "Projecto"
    ws["B4"] = ins.nome_projeto
    ws["A5"] = "Gerado em"
    ws["B5"] = dt.datetime.now().isoformat(timespec="seconds")

    # Proforma table
    start_row = 7
    ws[f"A{start_row}"] = "Linha"
    ws[f"B{start_row}"] = "R$"
    ws[f"C{start_row}"] = "% VGV"
    for c in ["A", "B", "C"]:
        cell = ws[f"{c}{start_row}"]
        cell.fill = header_fill
        cell.font = header_font
        cell.alignment = Alignment(horizontal="center")

    proforma = build_proforma_lines(res)
    for i, r in enumerate(proforma, start=1):
        rr = start_row + i
        ws[f"A{rr}"] = r["label"]
        ws[f"B{rr}"] = float(r["value"])
        ws[f"C{rr}"] = float(r["pct"]) / 100.0
        ws[f"B{rr}"].number_format = '"R$" #,##0'
        ws[f"C{rr}"].number_format = '0.00%'

    end_row = start_row + len(proforma)
    tab = Table(displayName="Proforma", ref=f"A{start_row}:C{end_row}")
    tab.tableStyleInfo = TableStyleInfo(
        name="TableStyleMedium9",
        showFirstColumn=False,
        showLastColumn=False,
        showRowStripes=True,
        showColumnStripes=False,
    )
    ws.add_table(tab)

    ws.column_dimensions["A"].width = 42
    ws.column_dimensions["B"].width = 16
    ws.column_dimensions["C"].width = 12

    # Segunda sheet: Premissas
    ws2 = wb.create_sheet("Premissas")
    ws2.append(["Campo", "Valor"])
    ws2["A1"].fill = header_fill
    ws2["B1"].fill = header_fill
    ws2["A1"].font = header_font
    ws2["B1"].font = header_font

    prem = asdict(ins)
    for k, v in prem.items():
        ws2.append([k, v])

    ws2.column_dimensions["A"].width = 34
    ws2.column_dimensions["B"].width = 22

    buf = io.BytesIO()
    wb.save(buf)
    return buf.getvalue()


