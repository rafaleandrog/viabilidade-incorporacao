        st.metric("Resultado final (A → B)", fmt_currency(a["res"]["resultado_final_r"]), fmt_currency(b["res"]["resultado_final_r"]))
    with colx3:
        delta = (b["res"]["resultado_final_r"] / a["res"]["resultado_final_r"] - 1.0) * 100.0 if a["res"]["resultado_final_r"] else 0.0
        st.metric("Δ Resultado final (%)", fmt_pct(delta, 2))
