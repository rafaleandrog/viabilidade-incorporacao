def proforma_df(res: Dict[str, float]) -> pd.DataFrame:
    lines = build_proforma_lines(res)
    return pd.DataFrame({
        "Linha": [x["label"] for x in lines],
        "R$": [x["value"] for x in lines],
        "% VGV": [x["pct"] for x in lines],
    })


def compare_two(a: Dict[str, float], b: Dict[str, float]) -> pd.DataFrame:
    dfa = proforma_df(a).set_index("Linha")
    dfb = proforma_df(b).set_index("Linha")
    out = dfa.join(dfb, lsuffix=" (A)", rsuffix=" (B)")
    out["Δ R$"] = out["R$ (B)"] - out["R$ (A)"]
    out["Δ %"] = out.apply(lambda r: (r["R$ (B)"] / r["R$ (A)"] - 1.0) * 100.0 if r["R$ (A)"] else 0.0, axis=1)
    return out.reset_index()


